{
  "name": "genshinquiz_web",
  "packageManager": "bun@1.2.23",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "bun vite",
    "dev:docker": "bun run build:api && bun vite",
    "build": "bun vite build",
    "build:api": "bunx orval --config orval.config.js && bun run lint:fix",
    "format": "bunx biome format src/",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --unsafe --write src/",
    "orval": "bunx orval --config orval.config.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/codemod": "^9.1.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-charts": "^9.9.0",
    "@mui/x-data-grid": "^9.9.0",
    "@mui/x-date-pickers": "^9.9.0",
    "ajv": "^8.20.0",
    "axios": "^1.18.1",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "luxon": "^3.7.2",
    "qs": "^6.15.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.18.1",
    "swr": "^2.4.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.4.3"
  },
