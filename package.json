    "@types/qs": "^6.15.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "orval": "^7.21.0",
    "typescript": "^7.0.2",
    "vite": "^6.4.3"
  }
}
